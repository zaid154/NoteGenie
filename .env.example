# ============================================================
# Demo / Seed login accounts (created by `npm run seed`)
#   Admin    -> admin@shop.com / Admin@123
#   Customer -> user@shop.com  / User@123
# ============================================================

# Server
PORT=
CLIENT_PORT=
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/notegenie?retryWrites=true&w=majority

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google Gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
ENCRYPTION_SECRET=

# SMTP (Gmail app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NoteGenie <you@example.com>

# Email OTP verification (signup). Account is created only AFTER the OTP is verified.
OTP_LENGTH=6
OTP_EXPIRES_MIN=10

# Razorpay (billing) — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Default plan prices in paise (used until admin sets prices in Admin → Billing)
RAZORPAY_PRO_AMOUNT=74900
RAZORPAY_TEAM_AMOUNT=249900

# Stripe (legacy, optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Seed account credentials
ADMIN_EMAIL=admin@shop.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin

USER_EMAIL=user@shop.com
USER_PASSWORD=User@123
USER_NAME=Demo User

# Support contact (Pricing page + Admin overview)
SUPPORT_EMAIL=

# Storefront contact + social links (FALLBACK defaults — Admin → Settings → Storefront overrides these)
WHATSAPP_NUMBER=          # digits only, no '+', e.g. 919350849407 (powers wa.me links; empty = hidden)
SOCIAL_INSTAGRAM=
SOCIAL_FACEBOOK=
SOCIAL_YOUTUBE=
SOCIAL_TELEGRAM=

# AI generation rate limit (overridable in Admin → AI Settings)
AI_RATE_LIMIT_MAX=120
AI_RATE_LIMIT_WINDOW_MIN=15

# Monitoring (optional)
SENTRY_DSN=
