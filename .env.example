# Ports (change if already in use on your machine)
PORT=5000              # Backend API (Express)
CLIENT_PORT=5173       # Frontend (React / Vite)
CLIENT_URL=http://localhost:5173   # Must match CLIENT_PORT (used for CORS)

# MongoDB Atlas connection string (Atlas dashboard -> Connect -> Drivers)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/notegenie

# JWT secret (koi bhi lambi random string)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google Gemini (fallback if admin has not set key in UI)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Seed accounts (npm run seed:admin) — creates one admin + one demo user
ADMIN_EMAIL=admin@notegenie.local
ADMIN_PASSWORD=admin123456
ADMIN_NAME=Admin

USER_EMAIL=user@notegenie.local
USER_PASSWORD=user123456
USER_NAME=Demo User
