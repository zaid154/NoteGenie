# ── Ports ─────────────────────────────────────────────────────────────
# Backend (Express API) and frontend (Vite). npm run dev reads these from
# the project root. If a port is busy, dev.mjs picks the next free one
# and prints the actual URLs in the terminal.
PORT=5001
CLIENT_PORT=3000
# Allowed browser origin(s) for CORS. Comma-separate multiple, e.g.
# CLIENT_URL=http://localhost:3000,https://app.example.com
CLIENT_URL=http://localhost:3000

# ── MongoDB ─────────────────────────────────────────────────────────
# Atlas: Dashboard → Connect → Drivers → copy connection string.
# If mongodb+srv:// fails (DNS), use the direct mongodb:// host list instead.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/notegenie

# ── Environment ─────────────────────────────────────────────────────
# Set to "production" when deploying. In production the server refuses to
# start if MONGO_URI / JWT_SECRET are missing or weak.
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────
# Use a long random value (min 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Google Gemini ───────────────────────────────────────────────────
# Used when no key is saved in Admin → AI Settings.
# You can also set the key in the admin UI (stored in MongoDB).
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Seed accounts (npm run seed:admin) ──────────────────────────────
# Creates one admin + one demo user if they don't exist yet.
# CHANGE these passwords before using anywhere real (min 8 chars).
ADMIN_EMAIL=admin@notegenie.local
ADMIN_PASSWORD=admin123456
ADMIN_NAME=Admin

USER_EMAIL=user@notegenie.local
USER_PASSWORD=user123456
USER_NAME=Demo User
