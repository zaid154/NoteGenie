# Frontend (Vite) environment.
#
# In local development you usually DON'T need this file — the dev server
# proxies "/api" to the backend automatically (see vite.config.js).
#
# For a production build where the API lives on a different origin, set the
# full API base URL (including the /api path):
#
#   VITE_API_URL=https://api.example.com/api
#
# Leave it unset to use the default relative "/api".
# VITE_API_URL=

# Storefront contact fallbacks (last-resort defaults before the storefront API resolves).
# Normally the server provides these from the DB / server env, so you can leave them blank.
# VITE_WHATSAPP_NUMBER=   # digits only, no '+', e.g. 919350849407
# VITE_SUPPORT_EMAIL=
