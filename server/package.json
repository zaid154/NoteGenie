{
  "name": "notegenie-server",
  "version": "1.0.0",
  "description": "NoteGenie backend - AI study assistant (PDF/link -> notes, quizzes, flashcards, tutor) powered by Gemini",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/scripts/seedData.js",
    "seed:data": "node src/scripts/seedData.js",
    "test": "node --test tests/api.test.js",
    "lint": "eslint . --max-warnings=99999",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.0.1",
    "nodemailer": "^9.0.1",
    "razorpay": "^2.9.6",
    "stripe": "^22.2.2",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "nodemon": "^3.1.9"
  }
}
